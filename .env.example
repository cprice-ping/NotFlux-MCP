# Bearer token issued by PingOne Orchestrate (Get Person Token flow).
# Primary user:    329ae312-ff58-4de6-b219-2823f9ca4d06
# Restricted user: 2ece0764-93cc-426c-980d-152f824928b1
ACCESS_TOKEN=

# The aud claim value that MCP-scoped tokens must carry.
# Must match PINGONE_MCP_AUDIENCE in the backend .env (the Token Exchange target resource).
# When unset, audience validation is skipped (local dev only).
EXPECTED_AUDIENCE=

# Exchange 2: mcp_token → kong_token (RFC 8693 Token Exchange)
# The MCP server exchanges the incoming mcp_token for a Kong-audience token
# before calling the NotFlux API. All four vars must be set to enable.
PINGONE_ENV_ID=59bb6a66-e76e-490c-b83a-884c50423da4
PINGONE_TX_CLIENT_ID=
PINGONE_TX_CLIENT_SECRET=
# Target audience for the Kong token (the NotFlux API resource audience)
PINGONE_KONG_AUDIENCE=

# Optional: port the HTTP server listens on (default: 8080)
PORT=8080
