# Base URL for the NotFlux API (defaults to public endpoint; override for in-cluster)
# NOTFLUX_API_BASE=http://notflux-api-kong-proxy
NOTFLUX_API_BASE=https://notflux-api.ping-devops.com

# Optional: port the HTTP server listens on (default: 8080)
PORT=8080

# ---------------------------------------------------------------------------
# OAuth 2.0 Resource Server / JWT validation (MCP spec §6, RFC 9470, RFC 6750)
# Set MCP_AUDIENCE to enable.  Leave blank to run without local JWT checks
# (Kong/AAM still enforces — this adds a spec-compliant layer at the MCP transport).
# ---------------------------------------------------------------------------
PINGONE_ENV_ID=59bb6a66-e76e-490c-b83a-884c50423da4

# MCP_ISSUER defaults to https://auth.pingone.com/${PINGONE_ENV_ID}/as
# MCP_ISSUER=

# `aud` claim the MCP Server validates in incoming tokens.
# The exchanged token will have an array `aud` — jose checks for membership.
# PingOne Resource setup:
#   Name:     NotFlux MCP Server
#   Audience: notflux-mcp          ← set this here
#   Scope:    use_mcp_tools        ← MCP-specific gate (see MCP_REQUIRED_SCOPE)
MCP_AUDIENCE=

# The MCP-specific scope to require on every inbound token.
# Should be the scope owned by the MCP Resource Server (e.g. use_mcp_tools),
# NOT get_media — that is Kong/AAM's job.
# get_media is obtained by the MCP Server's own second Token Exchange below.
MCP_REQUIRED_SCOPE=use_mcp_tools

# ---------------------------------------------------------------------------
# Second Token Exchange — MCP Server → NotFlux API  (RFC 8693)
#
# The MCP Server holds its own confidential client (RS client) and exchanges
# the inbound MCP token for a short-lived API-audience token before calling Kong.
# This means the agent / session state never holds a token usable against Kong.
#
# PingOne setup:
#   1. Create a Worker application — this is the MCP Server's identity
#      Grant type: Token Exchange
#      Token Exchange policy: actor=this client, subject=notflux-mcp resource tokens
#   2. Set MCP_API_AUDIENCE to the NotFlux API resource's audience value
# ---------------------------------------------------------------------------
MCP_RS_CLIENT_ID=
MCP_RS_CLIENT_SECRET=
# Audience of the NotFlux API resource in PingOne (what Kong's ping-auth validates)
MCP_API_AUDIENCE=
# Scope(s) to request on the outbound API token
MCP_API_SCOPE=get_media

# Public base URL of this server — used in WWW-Authenticate headers and
# the /.well-known/oauth-protected-resource discovery document.
MCP_PUBLIC_BASE_URL=https://notflux-mcp.ping-devops.com
