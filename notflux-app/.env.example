# Environment — backend
BACKEND_PORT=3001

# Vertex AI Agent Engine resource name
VERTEX_AGENT_RESOURCE=projects/3682147732/locations/us-west1/reasoningEngines/7712115294709219328

# NotFlux API base (backend → Kong).
# For local dev this hits the public hostname; in k8s override to http://notflux-api-kong-proxy
NOTFLUX_API_BASE=https://notflux-api.ping-devops.com

# ---------------------------------------------------------------------------
# PingOne Token Exchange — agent_token → mcp_token  (RFC 8693)
# Requires a confidential backend application in PingOne with Token Exchange grant.
# ---------------------------------------------------------------------------
PINGONE_ENV_ID=59bb6a66-e76e-490c-b83a-884c50423da4
PINGONE_TX_CLIENT_ID=
PINGONE_TX_CLIENT_SECRET=
# `aud` of the MCP Resource Server in PingOne (e.g. notflux-mcp).
# The exchanged token's `aud` will be an array containing BOTH this value
# AND the NotFlux API resource audience, because both scopes are requested.
# MCP Server validates `notflux-mcp` is in aud; Kong/AAM validates its own.
PINGONE_MCP_AUDIENCE=
# Scopes to request in the Token Exchange — request BOTH:
#   use_mcp_tools → owned by MCP resource         → satisfies MCP Server JWT check
#   (get_media is obtained by the MCP Server in its OWN second exchange below)
PINGONE_MCP_SCOPE=use_mcp_tools

# ---------------------------------------------------------------------------
# Agent token audience validation (defence-in-depth)
# Must match the `aud` and `scope` of the agent_token the frontend sends.
# ---------------------------------------------------------------------------
# Audience configured on the PingOne "agent" resource (e.g. https://google-agent)
PINGONE_AGENT_AUDIENCE=
PINGONE_AGENT_SCOPE=agent-use

# Allowed front-end origin
CORS_ORIGIN=http://localhost:5173
