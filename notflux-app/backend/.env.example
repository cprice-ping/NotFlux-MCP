# Environment — backend
BACKEND_PORT=3001

# ---------------------------------------------------------------------------
# GCP credentials — use a service account key (not user ADC) so the backend
# keeps running without interactive re-authentication (rapt_required).
#
# Create:
#   gcloud iam service-accounts create notflux-backend --project=<project>
#   gcloud projects add-iam-policy-binding <project> \
#     --member="serviceAccount:notflux-backend@<project>.iam.gserviceaccount.com" \
#     --role="roles/aiplatform.user"
#   gcloud iam service-accounts keys create ~/notflux-backend-sa.json \
#     --iam-account=notflux-backend@<project>.iam.gserviceaccount.com
#
# For k8s (non-GKE): mount the JSON as a Secret and point this env var at it.
# ---------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=/path/to/notflux-backend-sa.json

# Vertex AI Agent Engine resource name
VERTEX_AGENT_RESOURCE=projects/3682147732/locations/us-west1/reasoningEngines/7712115294709219328

# NotFlux API base (backend → Kong).
# For local dev this hits the public hostname; in k8s override to http://notflux-api-kong-proxy
NOTFLUX_API_BASE=https://notflux-api.ping-devops.com

# ---------------------------------------------------------------------------
# PingOne Token Exchange 1 — person_token → agent_token  (RFC 8693)
# Performed by the backend on every /api/sessions call.
# Requires a confidential application in PingOne with Token Exchange grant.
#
# The resulting agent_token is stored in Vertex session state.
# The Vertex Agent performs Exchange 2 (agent_token → mcp_token) at turn time,
# adding agent_id as a custom claim so PingOne policy can assert agent identity.
# ---------------------------------------------------------------------------
PINGONE_ENV_ID=59bb6a66-e76e-490c-b83a-884c50423da4
PINGONE_TX_CLIENT_ID=
PINGONE_TX_CLIENT_SECRET=
# Scope that PingOne maps to the agent resource server audience (controls what aud the agent_token gets).
PINGONE_AGENT_SCOPE=use_agent

# Allowed front-end origin
CORS_ORIGIN=http://localhost:5173
