# PingOne OIDC — primary login (person_token)
VITE_PINGONE_ENV_ID=59bb6a66-e76e-490c-b83a-884c50423da4
VITE_PINGONE_CLIENT_ID=5d24d1a9-851e-4cfb-8f94-d23d4b8b5be2

# ---------------------------------------------------------------------------
# Agent token (silent OIDC, prompt=none) — acquired after login
#
# Set VITE_PINGONE_AGENT_RESOURCE to the audience URI of your PingOne "agent"
# resource (the `aud` claim the Vertex Agent backend will validate).
# Leave blank to fall back to the person_token for agent calls (safe default).
#
# In PingOne:
#   1. Create a Resource with audience = <VITE_PINGONE_AGENT_RESOURCE>
#   2. Add scope "agent-use" to that resource
#   3. Authorise the SPA application for that resource
# ---------------------------------------------------------------------------
VITE_PINGONE_AGENT_RESOURCE=
VITE_PINGONE_AGENT_SCOPE=openid agent-use
