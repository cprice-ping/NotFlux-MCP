# Weather MCP Server environment variables
# Copy to .env and fill in your PingOne values

PORT=3150

# PingOne OIDC / JWKS config
# Format: https://auth.pingone.com/<ENV_ID>/as
PINGONE_ISSUER=https://auth.pingone.com/YOUR_ENV_ID/as

# Format: https://auth.pingone.com/<ENV_ID>/as/jwks
PINGONE_JWKS_URI=https://auth.pingone.com/YOUR_ENV_ID/as/jwks

# Set to "true" to disable JWT validation during local development (never in prod)
SKIP_AUTH=false

# Public URL of this server (used in WWW-Authenticate and resource metadata)
PUBLIC_URL=http://localhost:3150

# Comma-separated browser origins allowed to connect (DNS rebinding protection)
ALLOWED_ORIGINS=http://localhost:3000

# Audience URL of the PingOne Resource registered for this MCP server.
# Defaults to PUBLIC_URL if not set. Set to empty string to disable aud validation.
# This should match the Resource URL registered in PingOne for the weather server
# and the AUTH_MCP_WEATHER_RESOURCE value set in the web app's .env.
# MCP_AUDIENCE=http://localhost:3150
#
# NOTE: Do NOT set this to the travel server's URL. The token issued by auth.ts
# for this server is fetched via a separate refresh_token grant with
# resource=AUTH_MCP_WEATHER_RESOURCE, so the token's aud will be THIS server's URL.
