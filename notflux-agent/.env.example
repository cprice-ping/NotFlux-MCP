# notflux-agent — deployment env vars
# Copy to .env (gitignored) and fill in values before running deploy.py.
# Optionally install python-dotenv so deploy.py picks this up automatically:
#   pip install python-dotenv

# PingOne environment
PINGONE_ENV_ID=59bb6a66-e76e-490c-b83a-884c50423da4

# Confidential client for Exchange 2 (agent_token → mcp_token)
# Create a PingOne application with Token Exchange grant type.
PINGONE_CLIENT_ID=
PINGONE_CLIENT_SECRET=

# aud claim the agent validates on the incoming agent_token (must match
# PINGONE_AGENT_AUDIENCE in the notflux-app backend .env)
PINGONE_AGENT_AUDIENCE=

# aud to request in Exchange 2 — the MCP resource server identifier in PingOne
PINGONE_MCP_AUDIENCE=

# Vertex AI Agent Engine resource ID — fill in after the first `python deploy.py --create` run
# (the numeric ID printed in the output: projects/.../reasoningEngines/<ID>)
VERTEX_REASONING_ENGINE_ID=
